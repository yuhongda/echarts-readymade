{
  "name": "echarts-readymade",
  "version": "2.0.3",
  "description": "A collection of echarts templates for React. Based on echarts-for-react",
  "main": "lib/index.js",
  "module": "lib/es/index.es.js",
  "unpkg": "lib/umd/index.min.js",
  "jsdelivr": "lib/umd/index.min.js",
  "types": "types/index.d.ts",
  "files": [
    "lib/",
    "types/",
    "index.d.ts",
    "LICENSE",
    "README.md"
  ],
  "repository": "https://yuhongda@github.com/yuhongda/echarts-readymade.git",
  "author": "yuhongda",
  "license": "MIT",
  "scripts": {
    "lib": "babel src --out-dir lib --extensions \".js,.jsx,.ts,.tsx\" --config-file \"../../.babelrc.js\"",
    "cjs": "FORMAT=cjs rollup -c rollup.config.ts --configPlugin rollup-plugin-esbuild",
    "esm": "FORMAT=es rollup -c rollup.config.ts --configPlugin rollup-plugin-esbuild",
    "umd": "NODE_ENV=development FORMAT=umd rollup -c rollup.config.ts --configPlugin rollup-plugin-esbuild",
    "min": "NODE_ENV=production FORMAT=umd rollup -c rollup.config.ts --configPlugin rollup-plugin-esbuild",
    "dts": "tsc -p tsconfig.json",
    "build": "pnpm run clear && pnpm run lib && pnpm run dts && pnpm run cjs && pnpm run esm && pnpm run umd && pnpm run min",
    "clear": "rm -rf lib/ && rm -rf types/",
    "test": "jest",
    "jest:clear": "jest --clearCache",
    "cover": "pnpm run jest:clear && jest --coverage --config=jest.config.ts",
    "make-badges": "istanbul-badges-readme --coverageDir=__test__/coverage",
    "ci": "pnpm run build && pnpm run cover && codecov",
    "release": "npm publish",
    "release:next": "npm publish --tag next"
  },
  "dependencies": {
    "@echarts-readymade/bar": "workspace:*",
    "@echarts-readymade/bar-horizontal": "workspace:*",
    "@echarts-readymade/core": "workspace:*",
    "@echarts-readymade/line": "workspace:*",
    "@echarts-readymade/pie": "workspace:*",
    "@echarts-readymade/scatter": "workspace:*",
    "@echarts-readymade/stack": "workspace:*",
    "@echarts-readymade/table": "workspace:*",
    "@echarts-readymade/wordcloud": "workspace:*"
  },
  "devDependencies": {
    "@ant-design/icons": "^6.3.2",
    "@rollup/plugin-image": "^3.0.3",
    "antd": "^6.5.0",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependencies": {
    "@ant-design/icons": "^6.3.2",
    "antd": "^6.5.0",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "wordcloud": "^1.2.2"
  }
}
