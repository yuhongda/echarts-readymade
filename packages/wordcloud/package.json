{
  "name": "@echarts-readymade/wordcloud",
  "version": "2.0.3",
  "description": "Wordcloud chart",
  "main": "lib/index.js",
  "module": "lib/es/index.es.js",
  "unpkg": "lib/umd/index.min.js",
  "jsdelivr": "lib/umd/index.min.js",
  "types": "types/index.d.ts",
  "files": [
    "lib/",
    "types/",
    "typings/",
    "index.d.ts",
    "LICENSE",
    "README.md"
  ],
  "repository": "https://github.com/yuhongda/echarts-readymade.git",
  "author": "yuhongda",
  "license": "MIT",
  "scripts": {
    "lib": "babel src --out-dir lib --extensions \".js,.jsx,.ts,.tsx\" --config-file \"../../.babelrc.js\"",
    "cjs": "FORMAT=cjs rollup -c rollup.config.ts --configPlugin rollup-plugin-esbuild",
    "esm": "FORMAT=es rollup -c rollup.config.ts --configPlugin rollup-plugin-esbuild",
    "umd": "NODE_ENV=development FORMAT=umd rollup -c rollup.config.ts --configPlugin rollup-plugin-esbuild",
    "min": "NODE_ENV=production FORMAT=umd rollup -c rollup.config.ts --configPlugin rollup-plugin-esbuild",
    "dts": "tsc -p tsconfig.json",
    "image": "copyfiles -u 1 \"./src/assets/*.png\" lib",
    "build": "pnpm run clear && pnpm run lib && pnpm run dts && pnpm run cjs && pnpm run esm && pnpm run umd && pnpm run min && pnpm run image",
    "clear": "rm -rf lib/ && rm -rf types/",
    "test": "jest",
    "jest:clear": "jest --clearCache",
    "cover": "pnpm run jest:clear && jest --coverage --config=jest.config.ts",
    "make-badges": "istanbul-badges-readme --coverageDir=__test__/coverage",
    "ci": "pnpm run build && pnpm run cover && codecov",
    "release": "npm publish",
    "release:next": "npm publish --tag next"
  },
  "dependencies": {
    "@echarts-readymade/core": "workspace:*",
    "big.js": "^6.1.1",
    "clone": "^2.1.2",
    "styled-components": "^5.3.3"
  },
  "devDependencies": {
    "@rollup/plugin-image": "^3.0.3",
    "@types/big.js": "^6.1.2",
    "@types/clone": "^2.1.4",
    "@types/lodash": "^4.14.178",
    "@types/numeral": "^2.0.2",
    "@types/styled-components": "^5.1.20",
    "@types/wordcloud": "^1.2.2",
    "copyfiles": "^2.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "wordcloud": "^1.2.2"
  }
}
